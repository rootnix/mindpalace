{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "mp hook session-start || exit 0" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "mp hook stop || exit 0" }
        ]
      }
    ]
  }
}
