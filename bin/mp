#!/usr/bin/env python3
"""mp — mindpalace: a global engineering wiki for AI coding agents.

One wiki at ~/.mindpalace, shared by every coding agent (Claude Code, Codex,
...) across every project. Agents read it for context at session start and
write durable knowledge back as they work. Stdlib only.

Commands:
  mp init -g [--dry-run]       global setup: create the wiki, detect installed
                               agent tools, install all integrations. Supported:
                               claude, codex, gemini, copilot, antigravity,
                               windsurf, pi, hermes, cline, roo, kilocode
  mp init -g --agent <name>    install one integration (even if not detected)
  mp init --agent <name>       project-scoped integration file, versioned with
                               the repo (cursor, cline, roo, kilocode, windsurf)
  mp init --list               support matrix + per-tool integration status
  mp init [slug]               scaffold projects/<slug>/ for the current repo
  mp project                   resolve current project slug (git root name)
  mp context [slug]            project index + recent journal (session-start injection)
  mp jump <slug>               alias for context — pull another project's knowledge
  mp search <query...> [-p slug]   grep across the wiki, grouped by page
  mp list [slug]               list pages
  mp read <page>               print a page (path relative to the wiki root)
  mp write <page> [--force]    create a page from stdin (refuses overwrite without --force)
  mp edit <page> <old> <new>   exact-unique string replacement (THE update tool)
  mp log [slug] <note...>      append a dated entry to the project journal
  mp share                     make this project's wiki SHARED: creates
                               <repo>/.mindpalace (versioned with the repo),
                               seeds it from your global wiki; communal pages
                               + per-person journals (no merge conflicts)
  mp backfill [--limit N]      extract this project's PRE-mindpalace agent
                               sessions (Claude Code, Codex) into digests +
                               a distillation prompt; --clean removes digests
  mp upgrade                   update the mindpalace installation (git pull)

Wiki root: ~/.mindpalace (override with MINDPALACE_ROOT).
"""

from __future__ import annotations

import os
import re
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

ROOT = Path(os.environ.get("MINDPALACE_ROOT", Path.home() / ".mindpalace"))
INSTALL_DIR = Path(__file__).resolve().parent.parent

_PAGE_RE = re.compile(r"^(topics|projects)/[A-Za-z0-9._\-/ ]+\.md$")


def _die(msg: str, code: int = 1):
    print(f"mp: {msg}", file=sys.stderr)
    sys.exit(code)


def _today() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%d")


_LOCAL_PAGE_RE = re.compile(r"^(journal/)?[A-Za-z0-9._\- ]+\.md$")


def _safe_page(page: str) -> Path:
    page = page.strip().lstrip("/")
    if page.startswith(".mindpalace/"):
        page = page[len(".mindpalace/"):]  # accept `mp list` output verbatim
    store = _local_store()
    if store and not page.startswith(("topics/", "projects/")):
        # shared in-repo store: top-level pages + journal/<user>.md
        if ".." in page or not _LOCAL_PAGE_RE.match(page):
            _die(f"invalid page path for the shared store: {page!r}")
        return store / page
    if page in ("index.md", "README.md"):
        return ROOT / page
    if ".." in page or not _PAGE_RE.match(page):
        _die(f"invalid page path: {page!r} (use topics/x.md or projects/<slug>/x.md)")
    return ROOT / page


def _git_root(cwd: Path) -> Path | None:
    try:
        out = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"], cwd=cwd,
            capture_output=True, text=True, timeout=5,
        )
        if out.returncode == 0:
            return Path(out.stdout.strip())
    except Exception:
        pass
    return None


def _local_store(cwd: Path | None = None) -> Path | None:
    """In-repo shared store: <git root>/.mindpalace, if present.

    When a project has been `mp share`d, its wiki lives inside the repo and
    rides the project's own git — pages are communal (diff edits), journals
    are per-person (journal/<user>.md) so the append hot-path never conflicts.
    """
    root = _git_root(cwd or Path.cwd())
    if root:
        store = root / ".mindpalace"
        if store.is_dir():
            return store
    return None


def _username() -> str:
    try:
        out = subprocess.run(
            ["git", "config", "user.name"], capture_output=True, text=True, timeout=5,
        )
        name = out.stdout.strip()
    except Exception:
        name = ""
    name = name or os.environ.get("USER", "anon")
    return re.sub(r"[^A-Za-z0-9._-]+", "-", name).strip("-").lower() or "anon"


def _resolve_slug(args: list[str]) -> str:
    if args:
        return args[0]
    root = _git_root(Path.cwd())
    if root:
        marker = root / ".mindpalace-project"
        return marker.read_text().strip() if marker.exists() else root.name
    _die("no slug given and not in a git repo")


# ── wiki commands ────────────────────────────────────────────────────────────

def cmd_project(_args: list[str]) -> None:
    print(_resolve_slug([]))


def cmd_context(args: list[str]) -> None:
    store = _local_store() if not args else None
    if store:
        idx = store / "index.md"
        if idx.exists():
            print("## mindpalace (shared, in-repo): .mindpalace/index.md")
            print(idx.read_text().strip()[:3000])
        pages = sorted(
            p.name for p in store.glob("*.md")
            if p.name not in ("index.md", "README.md")
        )
        if pages:
            print("\n## mindpalace: other pages — read with `mp read <page>`")
            print(", ".join(pages))
        entries: list[str] = []
        for j in sorted(store.glob("journal/*.md")):
            who = j.stem
            entries += [
                f"{l} [{who}]" for l in j.read_text().splitlines()
                if l.startswith("- ")
            ]
        if entries:
            entries.sort()  # dated entries sort chronologically
            print("\n## mindpalace: recent journal (all members)")
            print("\n".join(entries[-8:]))
        return
    slug = _resolve_slug(args)
    pdir = ROOT / "projects" / slug
    if not pdir.exists():
        print(f"(mindpalace: no wiki yet for project '{slug}' — `mp init` to start one)")
        return
    idx = pdir / "index.md"
    if idx.exists():
        print(f"## mindpalace: projects/{slug}/index.md")
        print(idx.read_text().strip()[:3000])
    pages = sorted(
        p.name for p in pdir.glob("*.md") if p.name not in ("index.md", "journal.md")
    )
    if pages:
        print(f"\n## mindpalace: other pages — read with `mp read projects/{slug}/<page>`")
        print(", ".join(pages))
    journal = pdir / "journal.md"
    if journal.exists():
        entries = [l for l in journal.read_text().splitlines() if l.startswith("- ")]
        if entries:
            print("\n## mindpalace: recent journal")
            print("\n".join(entries[-6:]))


def cmd_search(args: list[str]) -> None:
    proj = None
    if "-p" in args:
        i = args.index("-p")
        proj = args[i + 1]
        args = args[:i] + args[i + 2:]
    if not args:
        _die("usage: mp search <query...> [-p slug]")
    query = " ".join(args)
    base = ROOT / "projects" / proj if proj else ROOT
    targets: list[tuple[Path, Path, str]] = []  # (base, root_for_rel, prefix)
    store = _local_store() if not proj else None
    if store:
        targets.append((store, store, ".mindpalace/"))
    if base.exists():
        targets.append((base, ROOT, ""))
    if not targets:
        _die("wiki not initialized — run `mp init -g`")
    hits: dict[str, list[str]] = {}
    terms = [t.lower() for t in query.split()]
    seen_paths: set = set()
    walk = [
        (path, prefix + str(path.relative_to(rroot)))
        for b, rroot, prefix in targets
        for path in sorted(b.rglob("*.md"))
    ]
    for path, rel in walk:
        if path in seen_paths:
            continue
        seen_paths.add(path)
        if "/.git/" in str(path) or rel.startswith(".git/"):
            continue
        try:
            lines = path.read_text(errors="replace").splitlines()
        except Exception:
            continue
        for n, line in enumerate(lines, 1):
            low = line.lower()
            if any(t in low for t in terms):
                hits.setdefault(rel, []).append(f"  {n}: {line.strip()[:160]}")
    if not hits:
        print(f"no hits for {query!r}")
        return
    for rel, lines in sorted(hits.items(), key=lambda kv: -len(kv[1]))[:10]:
        print(f"{rel} ({len(lines)} hit(s))")
        print("\n".join(lines[:5]))


def cmd_list(args: list[str]) -> None:
    store = _local_store() if not args else None
    if store:
        for path in sorted(store.rglob("*.md")):
            print(f".mindpalace/{path.relative_to(store)}")
    base = ROOT / "projects" / args[0] if args else ROOT
    if base.exists():
        for path in sorted(base.rglob("*.md")):
            rel = str(path.relative_to(ROOT))
            if not rel.startswith(".git/"):
                print(rel)


def cmd_read(args: list[str]) -> None:
    if not args:
        _die("usage: mp read <page>")
    path = _safe_page(args[0])
    if not path.exists():
        _die(f"not found: {args[0]}")
    print(path.read_text())


def cmd_write(args: list[str]) -> None:
    force = "--force" in args
    args = [a for a in args if a != "--force"]
    if not args:
        _die("usage: mp write <page> [--force] < content.md")
    path = _safe_page(args[0])
    if path.exists() and not force:
        _die(f"{args[0]} exists — use `mp edit` (diff) or --force for a deliberate rewrite")
    content = sys.stdin.read()
    if not content.strip():
        _die("empty content on stdin")
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content)
    print(f"wrote {args[0]} ({len(content)} chars)")


def cmd_edit(args: list[str]) -> None:
    if len(args) != 3:
        _die("usage: mp edit <page> <old_string> <new_string>")
    page, old, new = args
    path = _safe_page(page)
    if not path.exists():
        _die(f"not found: {page}")
    text = path.read_text()
    count = text.count(old)
    if count == 0:
        _die("old_string not found — copy the exact current text (whitespace matters)")
    if count > 1:
        _die(f"old_string appears {count} times — add surrounding context to make it unique")
    path.write_text(text.replace(old, new, 1))
    print(f"edited {page}")


def cmd_log(args: list[str]) -> None:
    if not args:
        _die("usage: mp log [slug] <note...>")
    store = _local_store()
    if store:
        note = " ".join(args)
        jdir = store / "journal"
        jdir.mkdir(exist_ok=True)
        journal = jdir / f"{_username()}.md"
        if not journal.exists():
            journal.write_text(
                f"# journal — {_username()}\n\nDated quick notes; distill durable ones into the shared pages.\n\n"
            )
        with journal.open("a") as f:
            f.write(f"- {_today()}: {note}\n")
        print(f"logged to .mindpalace/journal/{_username()}.md (commit with your changes)")
        return
    if (ROOT / "projects" / args[0]).exists() and len(args) > 1:
        slug, note = args[0], " ".join(args[1:])
    else:
        slug, note = _resolve_slug([]), " ".join(args)
    pdir = ROOT / "projects" / slug
    pdir.mkdir(parents=True, exist_ok=True)
    journal = pdir / "journal.md"
    if not journal.exists():
        journal.write_text(
            f"# {slug} journal\n\nDated quick notes; distill durable ones into pages.\n\n"
        )
    with journal.open("a") as f:
        f.write(f"- {_today()}: {note}\n")
    print(f"logged to projects/{slug}/journal.md")


# ── setup commands ───────────────────────────────────────────────────────────

def _init_project(args: list[str]) -> None:
    slug = _resolve_slug(args)
    pdir = ROOT / "projects" / slug
    pdir.mkdir(parents=True, exist_ok=True)
    idx = pdir / "index.md"
    if not idx.exists():
        idx.write_text(
            f"# {slug}\n\n(one-paragraph: what this project is, where it lives)\n\n"
            f"## Key facts\n\n## Pages\n"
        )
        print(f"created projects/{slug}/index.md — fill in the basics")
    else:
        print(f"projects/{slug}/ already exists")
    root = _git_root(Path.cwd())
    if root and root.name != slug and not (root / ".mindpalace-project").exists():
        (root / ".mindpalace-project").write_text(slug + "\n")
        print(f"wrote {root}/.mindpalace-project")


def _run(cmd: list[str], dry: bool) -> tuple[int, str]:
    if dry:
        print(f"  [dry-run] {' '.join(cmd)}")
        return 0, ""
    try:
        out = subprocess.run(cmd, capture_output=True, text=True, timeout=60)
        return out.returncode, (out.stdout + out.stderr).strip()
    except Exception as exc:
        return 1, str(exc)


_MP_BLOCK = """

<!-- MINDPALACE_START -->
## mindpalace — global engineering wiki

One cross-tool wiki at `~/.mindpalace` (CLI: `mp`), shared by all your
coding agents — read it for context, write durable knowledge back.

- Session start / new task: run `mp context` (project pages + recent
  journal). For anything beyond the current repo, `mp search <query>`.
- After substantial work: record durable knowledge — `mp log "<note>"`
  for dated quick notes, `mp edit <page> <old> <new>` for page updates
  (exact-unique string replacement — NEVER rewrite whole pages), and
  `mp write topics/<name>.md` for new cross-project pages.
- Discipline: diff edits only; date claims "(observed YYYY-MM-DD)"; fix
  stale content in place; the journal is an inbox — distill recurring
  themes into pages; nothing durable learned → write nothing.
- If the repo contains `.mindpalace/` (a SHARED team wiki versioned with
  the repo), mp commands use it automatically: top-level pages are
  communal, `journal/<user>.md` is yours. Commit wiki changes with your
  code changes.
<!-- MINDPALACE_END -->
"""

# Compact variant for hosts with tight size budgets (Windsurf caps the whole
# rules file at 6,000 chars; Hermes' SOUL.md is an off-label hook).
_MP_BLOCK_COMPACT = """

<!-- MINDPALACE_START -->
mindpalace: global engineering wiki at `~/.mindpalace` (CLI: `mp`), shared
by all your coding agents. Session start: run `mp context`; beyond this
repo: `mp search <query>`. After substantial work write durable knowledge
back: `mp log "<note>"` (dated note), `mp edit <page> <old> <new>`
(exact-unique diff edit — never rewrite whole pages), `mp write
topics/<name>.md` (new page). Date claims "(observed YYYY-MM-DD)"; nothing
durable learned → write nothing. A repo containing `.mindpalace/` is a
shared team wiki — mp uses it automatically; commit it with your code.
<!-- MINDPALACE_END -->
"""


def _integrations() -> list[dict]:
    """Registry of agent-tool integrations for `mp init -g`.

    kinds: plugin        — Claude Code plugin (hooks + skill)
           block         — append a marker-delimited block to a shared
                           global instructions file (idempotent: skipped
                           when MINDPALACE_START is already present, which
                           also dedupes tools sharing one file, e.g.
                           gemini + antigravity on ~/.gemini/GEMINI.md)
           block-compact — same, with the compact block
           rules         — own mindpalace.md inside the tool's global
                           rules directory (file is wholly ours)
           project       — no global mechanism; per-project file via
                           `mp init --agent <name>`
    """
    H = Path.home()
    copilot_home = Path(os.environ.get("COPILOT_HOME", str(H / ".copilot")))
    cline_dir = next((d for d in (H / "Documents" / "Cline" / "Rules",
                                  H / "Cline" / "Rules") if d.is_dir()), None)
    return [
        dict(name="claude", kind="plugin", detected=bool(shutil.which("claude")),
             target=None,
             note="plugin: session-start injection + stop nudge + mp skill"),
        dict(name="codex", kind="block", detected=(H / ".codex").is_dir(),
             target=H / ".codex" / "AGENTS.md", note=""),
        dict(name="gemini", kind="block", detected=(H / ".gemini").is_dir(),
             target=H / ".gemini" / "GEMINI.md", note=""),
        dict(name="antigravity", kind="block",
             detected=(H / ".gemini" / "antigravity").is_dir(),
             target=H / ".gemini" / "GEMINI.md",
             note="reads the same global file as gemini"),
        dict(name="copilot", kind="block", detected=copilot_home.is_dir(),
             target=copilot_home / "copilot-instructions.md", note=""),
        dict(name="windsurf", kind="block-compact",
             detected=(H / ".codeium" / "windsurf").is_dir(),
             target=H / ".codeium" / "windsurf" / "memories" / "global_rules.md",
             note="6,000-char file cap — compact block"),
        dict(name="pi", kind="block", detected=(H / ".pi").is_dir(),
             target=H / ".pi" / "agent" / "AGENTS.md", note=""),
        dict(name="hermes", kind="block-compact",
             detected=(H / ".hermes").is_dir(),
             target=H / ".hermes" / "SOUL.md",
             note="experimental: no official global instructions file"),
        dict(name="cline", kind="rules", detected=cline_dir is not None,
             target=(cline_dir or H / "Documents" / "Cline" / "Rules")
                    / "mindpalace.md",
             note=""),
        dict(name="roo", kind="rules", detected=(H / ".roo").is_dir(),
             target=H / ".roo" / "rules" / "mindpalace.md", note=""),
        dict(name="kilocode", kind="rules", detected=(H / ".kilocode").is_dir(),
             target=H / ".kilocode" / "rules" / "mindpalace.md", note=""),
        dict(name="cursor", kind="project", detected=(H / ".cursor").is_dir(),
             target=None,
             note="no global rules file — run `mp init --agent cursor` "
                  "inside each project"),
    ]


def _install_block(target: Path, block: str, dry: bool) -> str:
    if target.exists() and "MINDPALACE_START" in target.read_text():
        return "already integrated"
    if dry:
        return f"[dry-run] append mindpalace block to {target}"
    target.parent.mkdir(parents=True, exist_ok=True)
    existing = target.read_text() if target.exists() else ""
    target.write_text(existing + block)
    return f"appended block to {target}"


def _install_rules(target: Path, dry: bool) -> str:
    content = _MP_BLOCK.strip() + "\n"
    if target.exists() and target.read_text() == content:
        return "already integrated"
    if dry:
        return f"[dry-run] write {target}"
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(content)
    return f"wrote {target}"


def _install_claude_plugin(dry: bool) -> str:
    if not shutil.which("claude"):
        return "claude CLI not on PATH — install Claude Code first"
    mkt = str(INSTALL_DIR / "integrations" / "claude")
    rc, out = _run(["claude", "plugin", "marketplace", "add", mkt], dry)
    if rc != 0 and "already" in out.lower():
        _run(["claude", "plugin", "marketplace", "remove", "mindpalace-local"], dry)
        _run(["claude", "plugin", "marketplace", "add", mkt], dry)
    rc2, out2 = _run(
        ["claude", "plugin", "install", "mindpalace@mindpalace-local"], dry)
    if dry:
        return "[dry-run] install Claude Code plugin"
    if rc2 == 0 or "already installed" in out2.lower():
        return "plugin installed"
    return f"plugin install failed: {out2[:200]}"


def _list_integrations() -> None:
    print(f"{'agent':<12} {'status':<12} target")
    print("-" * 72)
    for it in _integrations():
        if it["kind"] == "plugin":
            status = "detected" if it["detected"] else "not found"
            target = "Claude Code plugin"
        elif it["kind"] == "project":
            status = "detected" if it["detected"] else "not found"
            target = "(project-scoped) " + it["note"]
        else:
            t: Path = it["target"]
            if t.exists() and "MINDPALACE" in t.read_text():
                status = "integrated"
            elif it["detected"]:
                status = "detected"
            else:
                status = "not found"
            target = str(t).replace(str(Path.home()), "~")
        print(f"{it['name']:<12} {status:<12} {target}")
        if it["note"] and it["kind"] not in ("project",):
            print(f"{'':<12} {'':<12}   {it['note']}")


def _init_global(dry: bool, agent: str | None = None) -> None:
    print(f"mindpalace install dir: {INSTALL_DIR}")
    print(f"wiki root: {ROOT}\n")

    # 1. wiki skeleton
    if ROOT.exists() and (ROOT / "index.md").exists():
        print("✓ wiki exists")
    elif dry:
        print(f"  [dry-run] create wiki skeleton at {ROOT}")
    else:
        ROOT.mkdir(parents=True, exist_ok=True)
        (ROOT / "topics").mkdir(exist_ok=True)
        (ROOT / "projects").mkdir(exist_ok=True)
        tpl = INSTALL_DIR / "templates"
        for name in ("README.md", "index.md"):
            src = tpl / name
            dst = ROOT / name
            if src.exists() and not dst.exists():
                shutil.copy(src, dst)
        if not (ROOT / ".git").exists():
            _run(["git", "-C", str(ROOT), "init", "-q"], dry=False)
        print(f"✓ wiki created at {ROOT} (its own git repo — add a private "
              f"remote for backup/team sync)")

    # 2. agent integrations
    registry = _integrations()
    names = [it["name"] for it in registry]
    if agent and agent not in names:
        _die(f"unknown agent {agent!r} — supported: {', '.join(names)}")
    hits = 0
    for it in registry:
        if agent and it["name"] != agent:
            continue
        if not it["detected"] and not agent:
            print(f"- {it['name']}: not found — skipped")
            continue
        if it["kind"] == "plugin":
            msg = _install_claude_plugin(dry)
        elif it["kind"] == "project":
            print(f"- {it['name']}: {it['note']}")
            continue
        elif it["kind"] == "rules":
            msg = _install_rules(it["target"], dry)
        else:
            block = _MP_BLOCK_COMPACT if it["kind"] == "block-compact" else _MP_BLOCK
            msg = _install_block(it["target"], block, dry)
        mark = "✗" if "failed" in msg or "not on PATH" in msg else "✓"
        extra = f" ({it['note']})" if it["note"] else ""
        print(f"{mark} {it['name']}: {msg}{extra}")
        hits += 1
    if agent and hits == 0:
        _die(f"agent {agent!r} matched nothing")

    print("\ndone. next: cd into a project and just start working — agents "
          "will read/write the wiki. Manual: mp context | mp search | mp log")


# Project-scoped integration files for tools without a global mechanism
# (or when a team wants the integration versioned with the repo).
_CURSOR_FRONTMATTER = """---
description: mindpalace — global engineering wiki for coding agents
alwaysApply: true
---
"""

_PROJECT_AGENT_FILES = {
    "cursor": (".cursor/rules/mindpalace.mdc", _CURSOR_FRONTMATTER),
    "cline": (".clinerules/mindpalace.md", ""),
    "roo": (".roo/rules/mindpalace.md", ""),
    "kilocode": (".kilocode/rules/mindpalace.md", ""),
    "windsurf": (".windsurf/rules/mindpalace.md", ""),
}


def _init_project_agent(agent: str, dry: bool) -> None:
    if agent not in _PROJECT_AGENT_FILES:
        _die(f"no project-scoped integration for {agent!r} — supported: "
             f"{', '.join(sorted(_PROJECT_AGENT_FILES))} "
             f"(others integrate globally via `mp init -g`)")
    root = _git_root(Path.cwd()) or _die("not inside a git repo")
    rel, prefix = _PROJECT_AGENT_FILES[agent]
    target = root / rel
    content = prefix + _MP_BLOCK.strip() + "\n"
    if target.exists() and target.read_text() == content:
        print(f"✓ {agent}: {rel} already integrated")
        return
    if dry:
        print(f"  [dry-run] write {target}")
        return
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(content)
    print(f"✓ {agent}: wrote {rel} — commit it with the repo")


def cmd_init(args: list[str]) -> None:
    dry = "--dry-run" in args
    args = [a for a in args if a != "--dry-run"]
    agent = None
    if "--agent" in args:
        i = args.index("--agent")
        if i + 1 >= len(args):
            _die("usage: mp init [-g] --agent <name>")
        agent = args[i + 1]
        del args[i:i + 2]
    if "--list" in args:
        _list_integrations()
        return
    if "-g" in args or "--global" in args:
        _init_global(dry, agent)
    elif agent:
        _init_project_agent(agent, dry)
    else:
        _init_project(args)


_SHARE_README = """\
# .mindpalace — shared project wiki

This project's knowledge base, versioned WITH the project. Every team
member's coding agents read it at session start and write back as they work.

Rules:
- Pages at the top level (index.md, decisions.md, gotchas.md, ...) are
  COMMUNAL — anyone updates them via `mp edit` (exact-unique diff edits;
  never rewrite whole pages). Date claims "(observed YYYY-MM-DD)".
- `journal/<user>.md` is PERSONAL — `mp log` writes only to your own file,
  so the append hot-path never merge-conflicts.
- Distill recurring journal themes into the communal pages.
- Cross-project knowledge belongs in your global wiki (`topics/`), not here.
"""


def cmd_share(_args: list[str]) -> None:
    """Create <git root>/.mindpalace and seed it from your global wiki."""
    root = _git_root(Path.cwd())
    if not root:
        _die("not inside a git repo")
    store = root / ".mindpalace"
    if store.exists():
        _die(".mindpalace already exists in this repo — it is already shared")
    slug = _resolve_slug([])
    store.mkdir()
    (store / "journal").mkdir()
    (store / "README.md").write_text(_SHARE_README)

    seeded = []
    gdir = ROOT / "projects" / slug
    if gdir.exists():
        for p in sorted(gdir.glob("*.md")):
            if p.name == "journal.md":
                dst = store / "journal" / f"{_username()}.md"
            else:
                dst = store / p.name
            shutil.copy(p, dst)
            seeded.append(dst.relative_to(store))
        # breadcrumb: global copy goes dormant, in-repo store is canonical
        (gdir / "index.md").write_text(
            f"# {slug} (shared)\n\nThis project's wiki moved INTO the repo: "
            f"`<repo>/.mindpalace/` (canonical since {_today()}). `mp` commands "
            f"run inside the repo use it automatically.\n"
        )
    if not (store / "index.md").exists():
        (store / "index.md").write_text(
            f"# {slug}\n\n(one-paragraph: what this project is)\n\n## Key facts\n"
        )

    print(f"shared store created: {store}")
    if seeded:
        print("seeded from your global wiki: " + ", ".join(str(s) for s in seeded))
    print("\nnext:")
    print(f"  git -C {root} add .mindpalace && git commit")
    print("  teammates: install mindpalace (`mp init -g`) — inside this repo,")
    print("  mp context/log/edit automatically use the shared store.")


def cmd_upgrade(_args: list[str]) -> None:
    if not (INSTALL_DIR / ".git").exists():
        _die(f"{INSTALL_DIR} is not a git checkout — reinstall via the install script")
    rc, out = _run(["git", "-C", str(INSTALL_DIR), "pull", "--ff-only"], dry=False)
    print(out or "up to date")
    sys.exit(rc)



# ── backfill: import pre-mindpalace sessions ─────────────────────────────────

_NOISE_RES = (
    re.compile(r"<system-reminder>.*?</system-reminder>", re.DOTALL),
    re.compile(r"<environment_context>.*?</environment_context>", re.DOTALL),
)
_USER_MSG_CAP = 1500
_ASSISTANT_MSG_CAP = 2500
_DIGEST_CAP = 60_000


def _clip(text: str, cap: int) -> str:
    for rx in _NOISE_RES:
        text = rx.sub("", text)
    text = text.strip()
    return text if len(text) <= cap else text[:cap] + " …[truncated]"


def _digest_claude(path: Path) -> list[tuple[str, str, str]]:
    """[(timestamp, role, text)] from a Claude Code session transcript."""
    import json
    turns = []
    for line in path.open(encoding="utf-8", errors="replace"):
        try:
            o = json.loads(line)
        except json.JSONDecodeError:
            continue
        if o.get("type") not in ("user", "assistant") or o.get("isSidechain"):
            continue
        content = (o.get("message") or {}).get("content")
        if isinstance(content, str):
            texts = [content]
        elif isinstance(content, list):
            texts = [b.get("text", "") for b in content if b.get("type") == "text"]
        else:
            continue
        cap = _USER_MSG_CAP if o["type"] == "user" else _ASSISTANT_MSG_CAP
        text = _clip("\n".join(t for t in texts if t), cap)
        if text:
            turns.append((str(o.get("timestamp", ""))[:16], o["type"], text))
    return turns


def _digest_codex(path: Path) -> list[tuple[str, str, str]]:
    """[(timestamp, role, text)] from a Codex rollout transcript."""
    import json
    turns = []
    for line in path.open(encoding="utf-8", errors="replace"):
        try:
            o = json.loads(line)
        except json.JSONDecodeError:
            continue
        p = o.get("payload") or {}
        if o.get("type") != "response_item" or p.get("type") != "message":
            continue
        role = p.get("role")
        if role not in ("user", "assistant"):
            continue
        texts = [b.get("text", "") for b in p.get("content") or []
                 if b.get("type") in ("input_text", "output_text")]
        cap = _USER_MSG_CAP if role == "user" else _ASSISTANT_MSG_CAP
        text = _clip("\n".join(t for t in texts if t), cap)
        if text and "<user_instructions>" not in text:
            turns.append((str(o.get("timestamp", ""))[:16], role, text))
    return turns


def _find_sessions(git_root: Path) -> list[tuple[str, Path]]:
    """[(tool, transcript_path)] for this project, oldest first by mtime."""
    import json
    found: list[tuple[str, Path]] = []
    claude_dir = Path.home() / ".claude" / "projects" / re.sub(
        r"[^A-Za-z0-9]", "-", str(git_root))
    if claude_dir.is_dir():
        found += [("claude", f) for f in claude_dir.glob("*.jsonl")]
    codex_root = Path.home() / ".codex" / "sessions"
    prefix = str(git_root)
    for f in codex_root.glob("**/*.jsonl") if codex_root.is_dir() else []:
        try:
            meta = json.loads(f.open(encoding="utf-8", errors="replace").readline())
        except (json.JSONDecodeError, OSError):
            continue
        cwd = str((meta.get("payload") or {}).get("cwd", ""))
        if meta.get("type") == "session_meta" and (
                cwd == prefix or cwd.startswith(prefix + "/")):
            found.append(("codex", f))
    return sorted(found, key=lambda t: t[1].stat().st_mtime)


def cmd_backfill(args: list[str]) -> None:
    """Extract pre-mindpalace session transcripts into digests an agent can
    distill into the wiki. mp has no LLM — it prepares the material and the
    prompt; your agent does the judgment."""
    slug = _resolve_slug([])
    out_dir = ROOT / ".backfill" / slug
    if "--clean" in args:
        if out_dir.is_dir():
            shutil.rmtree(out_dir)
            print(f"removed {out_dir}")
        else:
            print("nothing to clean")
        return
    limit = 0
    if "--limit" in args:
        try:
            limit = int(args[args.index("--limit") + 1])
        except (IndexError, ValueError):
            _die("usage: mp backfill [--limit N] [--clean]")

    git_root = _git_root(Path.cwd()) or _die("not in a git repo")
    sessions = _find_sessions(git_root)
    if limit:
        sessions = sessions[-limit:]
    if not sessions:
        _die("no Claude Code / Codex transcripts found for this project")

    out_dir.mkdir(parents=True, exist_ok=True)
    written = 0
    for i, (tool, f) in enumerate(sessions, 1):
        turns = _digest_claude(f) if tool == "claude" else _digest_codex(f)
        if not turns:
            continue
        lines = [f"# session digest — {tool} — {turns[0][0]} → {turns[-1][0]}",
                 f"source: {f}", ""]
        size = 0
        for ts, role, text in turns:
            block = f"## [{role}] {ts}\n{text}\n"
            if size + len(block) > _DIGEST_CAP:
                lines.append("…[digest truncated at cap]")
                break
            lines.append(block)
            size += len(block)
        name = f"{i:03d}-{tool}-{(turns[0][0] or 'undated')[:10]}.md"
        (out_dir / name).write_text("\n".join(lines), encoding="utf-8")
        written += 1
    print(f"{written} session digest(s) → {out_dir}\n")
    print("─" * 62)
    print(f"""Paste this into your agent (Claude Code, Codex, ...):

Backfill the mindpalace wiki for project '{slug}' from pre-mindpalace
session digests at {out_dir} ({written} files, chronological).
First run `mp context` and `mp list` to see the current wiki. Then read
the digests in order and distill ONLY durable knowledge:
- decisions, constraints, gotchas, architecture rationale -> `mp edit`
  diff-edits into existing pages (or `mp write` for a genuinely new page)
- dated events worth remembering -> `mp log`, quoting the original date
- skip anything the code already says, session chatter, one-off debugging
Date every claim with (observed YYYY-MM-DD) from the digest timestamps.
When done, run `mp backfill --clean` to delete the digests.""")
    print("─" * 62)


COMMANDS = {
    "init": cmd_init,
    "init-project": _init_project,  # back-compat alias
    "project": cmd_project,
    "context": cmd_context,
    "jump": cmd_context,
    "search": cmd_search,
    "list": cmd_list,
    "read": cmd_read,
    "write": cmd_write,
    "edit": cmd_edit,
    "log": cmd_log,
    "share": cmd_share,
    "backfill": cmd_backfill,
    "upgrade": cmd_upgrade,
}


def main() -> None:
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help", "help"):
        print(__doc__.strip())
        sys.exit(0)
    fn = COMMANDS.get(sys.argv[1])
    if not fn:
        _die(f"unknown command {sys.argv[1]!r} — run `mp help`")
    fn(sys.argv[2:])


if __name__ == "__main__":
    main()
